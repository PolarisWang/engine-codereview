# ── Feishu Bot Config ─────────────────────────────────────────────────────────
# Bot mode: set APP_ID+APP_SECRET for event subscription mode
# or WEBHOOK_URL for simple incoming webhook mode
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_WEBHOOK_VERIFY_TOKEN=
FEISHU_WEBHOOK_URL=

# ── Jenkins ──────────────────────────────────────────────────────────────────
JENKINS_URL=
JENKINS_USER=
JENKINS_TOKEN=
JENKINS_JOB_NAME=code-review-pipeline
FEISHU_CHAT_ID=

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_HOST=
JIRA_TOKEN=

# ── LLM API (Anthropic-compatible gateway) ──────────────────────────────────
# Use same settings as Claude Code global config
# The gateway at llm-api.booming-inc.com proxies to deepseek models
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://llm-api.booming-inc.com
ANTHROPIC_MODEL=deepseek-v4-flash

# ── Server ───────────────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=0

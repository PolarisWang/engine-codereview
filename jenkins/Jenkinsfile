#!/usr/bin/env groovy
/*
 * Code Review Pipeline
 *
 * Two modes:
 *   1. Scan mode (cron triggered, no JIRA_URL) — scan Jira for issues needing review
 *   2. Direct mode (JIRA_URL provided) — review a specific Jira issue
 *
 * Triggered by:
 *   - cron: every 30 minutes (scan mode)
 *   - manual: with JIRA_URL parameter
 *
 * Results are sent to Feishu group via webhook.
 */

pipeline {
    agent any

    triggers {
        cron('H/30 * * * *')
    }

    parameters {
        string(name: 'JIRA_URL', defaultValue: '',
               description: 'Jira issue URL (leave empty for auto-scan mode)')
    }

    environment {
        SCRIPTS_DIR = "${env.WORKSPACE}/jenkins/scripts"
        CONFIG_FILE = "${env.WORKSPACE}/config.yaml"
        REVIEW_WORKSPACE = "${env.WORKSPACE}/review-workspace"
        SCAN_RESULT_FILE = "${env.WORKSPACE}/scan_result.json"
        PARSED_INFO_FILE = "${env.WORKSPACE}/parsed_info.json"
        ENGINE_RESULT_FILE = "${env.WORKSPACE}/engine_result.json"
        GAME_RESULT_FILE = "${env.WORKSPACE}/game_result.json"
        REVIEWED_STATE_FILE = "/tmp/codereview-reviewed.json"   // Persist across runs
    }

    stages {
        // ──────────────────────────────────────────────
        // Stage 0: Scan — only when JIRA_URL is empty
        // ──────────────────────────────────────────────
        stage('Scan Jira Issues') {
            when { expression { params.JIRA_URL == null || params.JIRA_URL == '' } }
            steps {
                script {
                    sh """
                        python3 ${SCRIPTS_DIR}/jira_scanner.py \
                            --jira-host '${env.JIRA_HOST}' \
                            --jira-token '${env.JIRA_TOKEN}' \
                            --output '${SCAN_RESULT_FILE}' \
                            --state-file '${REVIEWED_STATE_FILE}'
                    """
                    scanResult = readJSON(file: SCAN_RESULT_FILE)
                    issues = scanResult.issues ?: []
                    echo "Found ${issues.size()} issues to review"

                    if (issues.isEmpty()) {
                        currentBuild.result = 'SUCCESS'
                    } else {
                        // Process first issue (one per run to keep results focused)
                        env.JIRA_URL = "https://${env.JIRA_HOST}/browse/${issues[0].key}"
                        echo "Auto-selected: ${env.JIRA_URL}"
                    }
                }
            }
        }

        // ──────────────────────────────────────────────
        // Stage 1: Parse Jira URL → project + MR info
        // ──────────────────────────────────────────────
        stage('Parse Jira Issue') {
            when { expression { params.JIRA_URL != null && params.JIRA_URL != '' } }
            steps {
                script {
                    sh """
                        python3 ${SCRIPTS_DIR}/jira_parser.py \
                            --jira-url '${params.JIRA_URL}' \
                            --jira-host '${env.JIRA_HOST}' \
                            --jira-token '${env.JIRA_TOKEN}' \
                            > ${PARSED_INFO_FILE}
                    """
                    parsedInfo = readJSON(file: PARSED_INFO_FILE)

                    if (parsedInfo.containsKey('error')) {
                        error("Jira parse failed: ${parsedInfo.error}")
                    }

                    env.ISSUE_KEY   = parsedInfo.issue_key
                    env.PROJECT     = parsedInfo.project
                    env.ENGINE_REPO = parsedInfo.engine_repo
                    env.GAME_REPO   = parsedInfo.game_repo
                    env.BASE_BRANCH = parsedInfo.default_branch

                    if (parsedInfo.mr_info != null && parsedInfo.mr_info.toString() != 'null') {
                        env.REVIEW_BRANCH = parsedInfo.mr_info.branch ?: parsedInfo.issue_key
                    } else {
                        env.REVIEW_BRANCH = parsedInfo.issue_key
                    }

                    echo "Parsed: ${env.ISSUE_KEY} → ${env.PROJECT}"
                    echo "Engine: ${env.ENGINE_REPO}"
                    echo "Game:   ${env.GAME_REPO}"
                    echo "Branch: ${env.REVIEW_BRANCH} → ${env.BASE_BRANCH}"
                }
            }
        }

        // ──────────────────────────────────────────────
        // Stage 2: Parallel Code Review (Engine + Game)
        // ──────────────────────────────────────────────
        stage('Code Review') {
            when { expression { env.ISSUE_KEY != null && env.ISSUE_KEY != '' } }
            parallel {
                stage('Engine Repo') {
                    steps {
                        script {
                            sh """
                                python3 ${SCRIPTS_DIR}/code_reviewer.py \
                                    --repo '${env.ENGINE_REPO}' \
                                    --branch '${env.REVIEW_BRANCH}' \
                                    --base-branch '${env.BASE_BRANCH}' \
                                    --project '${env.PROJECT}' \
                                    --issue-key '${env.ISSUE_KEY}' \
                                    --repo-type 'engine' \
                                    --workspace '${REVIEW_WORKSPACE}' \
                                    --output '${ENGINE_RESULT_FILE}'
                            """
                        }
                    }
                    post {
                        failure {
                            script {
                                writeJSON(file: ENGINE_RESULT_FILE, json: [
                                    project: env.PROJECT, issue_key: env.ISSUE_KEY,
                                    repo_type: 'engine', error: 'Review failed'
                                ])
                            }
                        }
                    }
                }

                stage('Game Repo') {
                    steps {
                        script {
                            sh """
                                python3 ${SCRIPTS_DIR}/code_reviewer.py \
                                    --repo '${env.GAME_REPO}' \
                                    --branch '${env.REVIEW_BRANCH}' \
                                    --base-branch '${env.BASE_BRANCH}' \
                                    --project '${env.PROJECT}' \
                                    --issue-key '${env.ISSUE_KEY}' \
                                    --repo-type 'game' \
                                    --workspace '${REVIEW_WORKSPACE}' \
                                    --output '${GAME_RESULT_FILE}'
                            """
                        }
                    }
                    post {
                        failure {
                            script {
                                writeJSON(file: GAME_RESULT_FILE, json: [
                                    project: env.PROJECT, issue_key: env.ISSUE_KEY,
                                    repo_type: 'game', error: 'Review failed'
                                ])
                            }
                        }
                    }
                }
            }
        }
    }

    // ──────────────────────────────────────────────
    // Post: Send results to Feishu + update state
    // ──────────────────────────────────────────────
    post {
        success {
            script {
                if (env.ISSUE_KEY == null || env.ISSUE_KEY == '') {
                    echo "No issues to review — skipping notification"
                    return
                }

                def engineResult = fileExists(ENGINE_RESULT_FILE) ? readJSON(file: ENGINE_RESULT_FILE) : [:]
                def gameResult   = fileExists(GAME_RESULT_FILE)   ? readJSON(file: GAME_RESULT_FILE)   : [:]
                def feishuWebhook = env.FEISHU_WEBHOOK_URL ?: ''

                // Build severity summary
                def buildSevText = { result ->
                    def sev = result.review?.severity_counts ?: [:]
                    def parts = []
                    if (sev.critical)  parts.append("🔴 ${sev.critical}")
                    if (sev.warning)   parts.append("🟡 ${sev.warning}")
                    if (sev.suggestion)parts.append("ℹ️ ${sev.suggestion}")
                    return parts ? parts.join(' | ') : '✅ Clean'
                }
                engineSev = buildSevText(engineResult)
                gameSev   = buildSevText(gameResult)

                // Count changed files
                def engineFiles = (engineResult.changed_files ?: []).size()
                def gameFiles   = (gameResult.changed_files   ?: []).size()

                // Send via webhook
                if (feishuWebhook) {
                    def msgText = """✅ Code Review Complete: ${env.ISSUE_KEY}
Project: ${env.PROJECT}
Jira: ${params.JIRA_URL}

🔧 Engine (${engineFiles} files): ${engineSev}
🎮 Game (${gameFiles} files): ${gameSev}

${BUILD_URL}"""
                    writeJSON(file: 'feishu_msg.json', json: msgText)
                    sh """
                        python3 ${SCRIPTS_DIR}/feishu_notifier.py webhook \
                            --webhook-url '${feishuWebhook}' \
                            --message-file '${env.WORKSPACE}/feishu_msg.json'
                    """
                }

                // Mark as reviewed in state file
                def state = [:]
                if (fileExists(REVIEWED_STATE_FILE)) {
                    state = readJSON(file: REVIEWED_STATE_FILE)
                }
                def reviewed = state.reviewed ?: []
                if (!(env.ISSUE_KEY in reviewed)) {
                    reviewed.add(env.ISSUE_KEY)
                    // Keep last 200, trim oldest
                    if (reviewed.size() > 200) {
                        reviewed = reviewed[-200..-1]
                    }
                    writeJSON(file: REVIEWED_STATE_FILE, json: [reviewed: reviewed])
                    echo "Marked ${env.ISSUE_KEY} as reviewed"
                }
            }
        }

        failure {
            script {
                if (env.ISSUE_KEY != null && env.ISSUE_KEY != '') {
                    def feishuWebhook = env.FEISHU_WEBHOOK_URL ?: ''
                    if (feishuWebhook) {
                        def msgText = "❌ Code Review Failed: ${env.ISSUE_KEY}\nBuild: ${BUILD_URL}"
                        writeJSON(file: 'feishu_err_msg.json', json: msgText)
                        sh """
                            python3 ${SCRIPTS_DIR}/feishu_notifier.py webhook \
                                --webhook-url '${feishuWebhook}' \
                                --message-file '${env.WORKSPACE}/feishu_err_msg.json'
                        """
                    }
                }
            }
        }

        cleanup {
            sh "rm -rf ${REVIEW_WORKSPACE} ${SCAN_RESULT_FILE} ${PARSED_INFO_FILE} ${ENGINE_RESULT_FILE} ${GAME_RESULT_FILE} ${env.WORKSPACE}/engine_review.json ${env.WORKSPACE}/game_review.json ${env.WORKSPACE}/feishu_msg.json ${env.WORKSPACE}/feishu_err_msg.json || true"
        }
    }
}

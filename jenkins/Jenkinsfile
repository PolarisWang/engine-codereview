#!/usr/bin/env groovy
/*
 * Code Review Pipeline
 *
 * Two modes:
 *   1. Scan mode (cron triggered, no JIRA_URL) — poll Feishu group for new
 *      topic messages containing Jira URLs, reply in-thread with review results
 *   2. Direct mode (JIRA_URL provided) — review a specific Jira issue
 *
 * Triggered by:
 *   - cron: every 30 seconds (scan mode)
 *   - manual: with JIRA_URL parameter
 *
 * Requires Jenkins global env vars:
 *   JIRA_HOST, JIRA_TOKEN — Jira API access
 *   GITLAB_TOKEN — GitLab API for MR branch detection
 *   FEISHU_APP_ID, FEISHU_APP_SECRET — Feishu bot credentials
 */

pipeline {
    agent any

    triggers {
        cron('* * * * *')
    }

    parameters {
        string(name: 'JIRA_URL', defaultValue: '',
               description: 'Jira issue URL (leave empty for auto-scan mode)')
        string(name: 'FEISHU_REPLY_MSG_ID', defaultValue: '',
               description: 'Feishu message ID to reply in (leave empty for new topic)')
    }

    environment {
        SCRIPTS_DIR = "${env.WORKSPACE}/jenkins/scripts"
        CONFIG_FILE = "${env.WORKSPACE}/config.yaml"
        REVIEW_WORKSPACE = "${env.WORKSPACE}/review-workspace"
        SCAN_RESULT_FILE = "${env.WORKSPACE}/scan_result.json"
        PARSED_INFO_FILE = "${env.WORKSPACE}/parsed_info.json"
        ENGINE_RESULT_FILE = "${env.WORKSPACE}/engine_result.json"
        GAME_RESULT_FILE = "${env.WORKSPACE}/game_result.json"
        REVIEWED_STATE_FILE = "${env.WORKSPACE}/.codereview-feishu-state.json"   // Feishu scanner state (processed msg IDs)

        // GitLab token for HTTPS clone + MR branch detection
        GITLAB_TOKEN = "${env.GITLAB_TOKEN ?: ''}"
        GITLAB_USER = "gitlab-ci-token"

        // Feishu Bot API (for topic messages)
        FEISHU_APP_ID = "${env.FEISHU_APP_ID ?: ''}"
        FEISHU_APP_SECRET = "${env.FEISHU_APP_SECRET ?: ''}"
        FEISHU_CHAT_ID = "${env.FEISHU_CHAT_ID ?: 'oc_254e95f0687245b9df82ab8bf823ca54'}"
        // Fallback webhook
        FEISHU_WEBHOOK_URL = "${env.FEISHU_WEBHOOK_URL_OVERRIDE ?: 'https://open.feishu.cn/open-apis/bot/v2/hook/f2ec1781-06d2-42c8-91b4-37616d973970'}"

        // Jira credentials (injected via Jenkins global env or credentials)
        JIRA_HOST = "${env.JIRA_HOST ?: ''}"
        JIRA_TOKEN = "${env.JIRA_TOKEN ?: ''}"
    }

    stages {
        // ──────────────────────────────────────────────
        // Stage 0: Scan Feishu — only when JIRA_URL is empty
        // ──────────────────────────────────────────────
        stage('Scan Feishu Messages') {
            when { expression { params.JIRA_URL == null || params.JIRA_URL == '' } }
            steps {
                script {
                    sh """
                        python3 ${SCRIPTS_DIR}/feishu_scanner.py \
                            --app-id '${env.FEISHU_APP_ID}' \
                            --app-secret '${env.FEISHU_APP_SECRET}' \
                            --chat-id '${env.FEISHU_CHAT_ID}' \
                            --jira-host '${env.JIRA_HOST}' \
                            --state-file '${REVIEWED_STATE_FILE}' \
                            --output '${SCAN_RESULT_FILE}'
                    """
                    scanResult = readJSON(file: SCAN_RESULT_FILE)
                    items = scanResult.items ?: []
                    echo "Found ${items.size()} Jira URLs to review"

                    if (items.isEmpty()) {
                        currentBuild.result = 'SUCCESS'
                    } else {
                        echo "Processing ${items.size()} detected Jira URLs"
                        // Deduplicate by issue_key: only process the first message per issue
                        def uniqueIssues = items.groupBy { it.issue_key }.collect { k, v -> v[0] }

                        // Cross-build dedup: check if we've already reviewed these issues
                        // by reading the reviewed_issues state file
                        def processedStateFile = "${env.WORKSPACE}/.codereview-reviewed.json"
                        def reviewedIssues = [:]
                        if (fileExists(processedStateFile)) {
                            try {
                                reviewedIssues = readJSON(file: processedStateFile)
                            } catch (Exception e) {
                                reviewedIssues = [:]
                            }
                        }
                        def unprocessedIssues = uniqueIssues.findAll { item ->
                            !reviewedIssues.containsKey(item.issue_key)
                        }
                        if (unprocessedIssues.size() < uniqueIssues.size()) {
                            echo "Filtered ${uniqueIssues.size() - unprocessedIssues.size()} already-reviewed issues"
                        }
                        if (unprocessedIssues.isEmpty()) {
                            echo "All issues already reviewed in previous builds"
                            currentBuild.result = 'SUCCESS'
                            return
                        }
                        echo "Processing ${unprocessedIssues.size()} new Jira issues"

                        def issueBuilds = [:]
                        unprocessedIssues.each { item ->
                            def issueKey = item.issue_key
                            def jiraUrl = item.jira_url
                            def msgId = item.message_id
                            issueBuilds[issueKey] = {
                                def engFile = "${env.WORKSPACE}/result_${issueKey}_engine.json"
                                def gamFile = "${env.WORKSPACE}/result_${issueKey}_game.json"
                                def infoFile = "${env.WORKSPACE}/parsed_${issueKey}.json"

                                // Step 1: Reply "reviewing..." in Feishu thread (use writeFile to avoid echo + emoji issues)
                                def progressText = "🤖 **正在 Review...**\n已收到 ${issueKey}，正在拉取代码并进行 AI 审查，请稍候..."
                                writeFile(file: "${env.WORKSPACE}/.fs_progress_${issueKey}.txt",
                                    text: progressText)
                                sh """
                                    python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                        --app-id '${env.FEISHU_APP_ID}' \
                                        --app-secret '${env.FEISHU_APP_SECRET}' \
                                        --chat-id '${env.FEISHU_CHAT_ID}' \
                                        --message-id '${msgId}' \
                                        --message-file '${env.WORKSPACE}/.fs_progress_${issueKey}.txt'
                                """

                                // Step 2: Parse Jira → project + MR info
                                sh """
                                    python3 ${SCRIPTS_DIR}/jira_parser.py \
                                        --jira-url '${jiraUrl}' \
                                        --jira-host '${env.JIRA_HOST}' \
                                        --jira-token '${env.JIRA_TOKEN}' \
                                        --gitlab-token '${env.GITLAB_TOKEN}' \
                                        > ${infoFile}
                                """
                                def parsedInfo = readJSON(file: infoFile)
                                if (parsedInfo.containsKey('error')) {
                                    def errMsg = "❌ **Review Failed**: ${issueKey}\n无法解析 Jira 信息: ${parsedInfo.error}"
                                    writeFile(file: "${env.WORKSPACE}/.fs_err_${issueKey}.txt", text: errMsg)
                                    sh """
                                        python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                            --app-id '${env.FEISHU_APP_ID}' \
                                            --app-secret '${env.FEISHU_APP_SECRET}' \
                                            --chat-id '${env.FEISHU_CHAT_ID}' \
                                            --message-id '${msgId}' \
                                            --message-file '${env.WORKSPACE}/.fs_err_${issueKey}.txt'
                                    """
                                    return
                                }
                                def mrInfo = parsedInfo.mr_info
                                if (mrInfo instanceof net.sf.json.JSONNull) mrInfo = null
                                def reviewBranch = mrInfo?.branch ?: issueKey
                                def baseBranch = mrInfo?.target_branch ?: parsedInfo.default_branch ?: 'master'
                                def engineRepo = parsedInfo.engine_repo
                                def gameRepo = parsedInfo.game_repo
                                def project = parsedInfo.project
                                echo "Review ${issueKey}: branch=${reviewBranch}, base=${baseBranch}, project=${project}"

                                // Step 3: Parallel code review (engine + game)
                                sh """
                                    python3 ${SCRIPTS_DIR}/code_reviewer.py \
                                        --repo '${engineRepo}' \
                                        --branch '${reviewBranch}' \
                                        --base-branch '${baseBranch}' \
                                        --project '${project}' \
                                        --issue-key '${issueKey}' \
                                        --repo-type 'engine' \
                                        --workspace '${REVIEW_WORKSPACE}' \
                                        --output '${engFile}'
                                    python3 ${SCRIPTS_DIR}/code_reviewer.py \
                                        --repo '${gameRepo}' \
                                        --branch '${reviewBranch}' \
                                        --base-branch '${baseBranch}' \
                                        --project '${project}' \
                                        --issue-key '${issueKey}' \
                                        --repo-type 'game' \
                                        --workspace '${REVIEW_WORKSPACE}' \
                                        --output '${gamFile}'
                                """
                                def engineResult = fileExists(engFile) ? readJSON(file: engFile) : [:]
                                def gameResult = fileExists(gamFile) ? readJSON(file: gamFile) : [:]

                                // Step 4: Build informative summary (never just "CLEAN")
                                def engSev = engineResult.review?.severity_counts
                                if (engSev == null || engSev instanceof net.sf.json.JSONNull) engSev = [:]
                                def gamSev = gameResult.review?.severity_counts
                                if (gamSev == null || gamSev instanceof net.sf.json.JSONNull) gamSev = [:]
                                def engChanged = (engineResult.changed_files ?: []).size()
                                def gamChanged = (gameResult.changed_files ?: []).size()
                                def engFiles = (engineResult.changed_files ?: []).collect { line -> line.split("\t").size() > 1 ? line.split("\t")[1] : line.split("\\s+").size() > 1 ? line.split("\\s+")[1] : line }
                                def gamFiles = (gameResult.changed_files ?: []).collect { line -> line.split("\t").size() > 1 ? line.split("\t")[1] : line.split("\\s+").size() > 1 ? line.split("\\s+")[1] : line }
                                def engStats = engineResult.stats ?: ""
                                def gamStats = gameResult.stats ?: ""
                                def engCommits = engineResult.commits ?: ""
                                def gamCommits = gameResult.commits ?: ""
                                def engError = engineResult.review?.error ?: engineResult.error ?: ""
                                def gamError = gameResult.review?.error ?: gameResult.error ?: ""

                                // Build engine section — determine precise reason for no diff
                                def engText = ""
                                def engBranchMerged = engineResult.branch_merged ?: false
                                def engBranchExists = engineResult.containsKey('branch_exists') ? engineResult.branch_exists : true
                                def mrState = parsedInfo.mr_info?.state ?: ""
                                if (engError) {
                                    engText = "🔧 **Engine 仓库** ❌ 审查失败\n原因: ${engError}"
                                } else if (!engBranchExists) {
                                    engText = "🔧 **Engine 仓库** ⏭️ 跳过审查\n原因: 分支 `${reviewBranch}` 在远程仓库中不存在（可能已被删除或从未创建）"
                                } else if (engBranchMerged) {
                                    def mergedHint = ""
                                    if (mrState == "merged") mergedHint = "GitLab 显示该 MR 已合并"
                                    else if (mrState == "closed") mergedHint = "GitLab 显示该 MR 已关闭"
                                    engText = "🔧 **Engine 仓库** ⏭️ 跳过审查\n原因: 分支 `${reviewBranch}` 已经合并到 `${baseBranch}`，没有新的代码变更${mergedHint ? '（' + mergedHint + '）' : ''}"
                                } else if (engChanged == 0) {
                                    engText = "🔧 **Engine 仓库** ⏭️ 跳过审查\n原因: 该分支相对于 ${baseBranch} 没有代码变更"
                                } else {
                                    engText = "🔧 **Engine 仓库**\n变更文件: ${engChanged} 个"
                                    if (engStats) engText += " (${engStats})"
                                    if (engSev.get('critical'))  engText += "\n🔴 Critical: ${engSev.get('critical')}"
                                    if (engSev.get('warning'))   engText += "\n🟡 Warning: ${engSev.get('warning')}"
                                    if (engSev.get('suggestion')) engText += "\nℹ️ Suggestion: ${engSev.get('suggestion')}"
                                    if (!engSev.get('critical') && !engSev.get('warning') && !engSev.get('suggestion')) {
                                        engText += "\n✅ 未发现严重问题"
                                    }
                                }

                                // Build game section
                                def gamText = ""
                                def gamBranchMerged = gameResult.branch_merged ?: false
                                def gamBranchExists = gameResult.containsKey('branch_exists') ? gameResult.branch_exists : true
                                if (gamError) {
                                    gamText = "🎮 **Game 仓库** ❌ 审查失败\n原因: ${gamError}"
                                } else if (!gamBranchExists) {
                                    gamText = "🎮 **Game 仓库** ⏭️ 跳过审查\n原因: 分支 `${reviewBranch}` 在远程仓库中不存在（可能已被删除或从未创建）"
                                } else if (gamBranchMerged) {
                                    gamText = "🎮 **Game 仓库** ⏭️ 跳过审查\n原因: 分支 `${reviewBranch}` 已经合并到 `${baseBranch}`，没有新的代码变更"
                                } else if (gamChanged == 0) {
                                    gamText = "🎮 **Game 仓库** ⏭️ 跳过审查\n原因: 该分支相对于 ${baseBranch} 没有代码变更"
                                } else {
                                    gamText = "🎮 **Game 仓库**\n变更文件: ${gamChanged} 个"
                                    if (gamStats) gamText += " (${gamStats})"
                                    if (gamSev.get('critical'))  gamText += "\n🔴 Critical: ${gamSev.get('critical')}"
                                    if (gamSev.get('warning'))   gamText += "\n🟡 Warning: ${gamSev.get('warning')}"
                                    if (gamSev.get('suggestion')) gamText += "\nℹ️ Suggestion: ${gamSev.get('suggestion')}"
                                    if (!gamSev.get('critical') && !gamSev.get('warning') && !gamSev.get('suggestion')) {
                                        gamText += "\n✅ 未发现严重问题"
                                    }
                                }

                                def mrUrl = parsedInfo.mr_url ?: ''
                                def summaryText = "**🔍 Code Review 报告: ${issueKey}**\n\n"
                                summaryText += "**项目:** ${project}\n"
                                summaryText += "**分支:** ${reviewBranch} → ${baseBranch}\n"
                                if (mrUrl) summaryText += "**MR:** ${mrUrl}\n"
                                summaryText += "\n${engText}\n"
                                summaryText += "\n${gamText}\n"
                                summaryText += "\n---\n📎 Jira: ${jiraUrl}"

                                writeFile(file: "${env.WORKSPACE}/.fs_summary_${issueKey}.txt",
                                    text: summaryText)
                                sh """
                                    python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                        --app-id '${env.FEISHU_APP_ID}' \
                                        --app-secret '${env.FEISHU_APP_SECRET}' \
                                        --chat-id '${env.FEISHU_CHAT_ID}' \
                                        --message-id '${msgId}' \
                                        --message-file '${env.WORKSPACE}/.fs_summary_${issueKey}.txt'
                                """

                                // Step 5: Reply with engine detail (if any findings)
                                if (engineResult.review?.review_text) {
                                    def detail = engineResult.review.review_text
                                    def maxLen = 3000
                                    if (detail.length() > maxLen) {
                                        detail = detail.substring(0, maxLen) + "\n\n...（剩余内容请在 Jenkins 构建日志中查看）"
                                    }
                                    writeFile(file: "${env.WORKSPACE}/.fs_engine_${issueKey}.txt",
                                              text: "**🔧 Engine 详细报告:**\n${detail}")
                                    sh """
                                        python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                            --app-id '${env.FEISHU_APP_ID}' \
                                            --app-secret '${env.FEISHU_APP_SECRET}' \
                                            --chat-id '${env.FEISHU_CHAT_ID}' \
                                            --message-id '${msgId}' \
                                            --message-file '${env.WORKSPACE}/.fs_engine_${issueKey}.txt'
                                    """
                                }

                                // Step 6: Reply with game detail (if any findings)
                                if (gameResult.review?.review_text) {
                                    def detail = gameResult.review.review_text
                                    def maxLen = 3000
                                    if (detail.length() > maxLen) {
                                        detail = detail.substring(0, maxLen) + "\n\n...（剩余内容请在 Jenkins 构建日志中查看）"
                                    }
                                    writeFile(file: "${env.WORKSPACE}/.fs_game_${issueKey}.txt",
                                              text: "**🎮 Game 详细报告:**\n${detail}")
                                    sh """
                                        python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                            --app-id '${env.FEISHU_APP_ID}' \
                                            --app-secret '${env.FEISHU_APP_SECRET}' \
                                            --chat-id '${env.FEISHU_CHAT_ID}' \
                                            --message-id '${msgId}' \
                                            --message-file '${env.WORKSPACE}/.fs_game_${issueKey}.txt'
                                    """
                                }

                                echo "Completed review for ${issueKey}"
                                // Persist to cross-build dedup state
                                def processedStateFile = "${env.WORKSPACE}/.codereview-reviewed.json"
                                def revState = [:]
                                if (fileExists(processedStateFile)) {
                                    try { revState = readJSON(file: processedStateFile) } catch (Exception e) {}
                                }
                                revState[issueKey] = "${currentBuild.number}"
                                writeJSON(file: processedStateFile, json: revState)
                            }
                        }
                        parallel issueBuilds
                    }
                }
            }
        }

        // ──────────────────────────────────────────────
        // Stage 1: Parse Jira URL → project + MR info
        // ──────────────────────────────────────────────
        stage('Parse Jira Issue') {
            when {
                expression { params.JIRA_URL != null && params.JIRA_URL != '' }
            }
            steps {
                script {
                    sh """
                        python3 ${SCRIPTS_DIR}/jira_parser.py \
                            --jira-url '${params.JIRA_URL}' \
                            --jira-host '${env.JIRA_HOST}' \
                            --jira-token '${env.JIRA_TOKEN}' \
                            --gitlab-token '${env.GITLAB_TOKEN}' \
                            > ${PARSED_INFO_FILE}
                    """
                    parsedInfo = readJSON(file: PARSED_INFO_FILE)

                    if (parsedInfo.containsKey('error')) {
                        error("Jira parse failed: ${parsedInfo.error}")
                    }

                    env.ISSUE_KEY   = parsedInfo.issue_key
                    env.PROJECT     = parsedInfo.project
                    env.ENGINE_REPO = parsedInfo.engine_repo
                    env.GAME_REPO   = parsedInfo.game_repo
                    env.BASE_BRANCH = parsedInfo.default_branch
                    env.ENGINE_BASE_BRANCH = parsedInfo.containsKey('engine_default_branch') ? parsedInfo.engine_default_branch : parsedInfo.default_branch
                    env.MR_URL      = parsedInfo.mr_url ?: ''

                    if (parsedInfo.mr_info != null && parsedInfo.mr_info.toString() != 'null') {
                        env.REVIEW_BRANCH = parsedInfo.mr_info.branch ?: parsedInfo.issue_key
                        // Use MR target_branch as base if available
                        if (parsedInfo.mr_info.target_branch) {
                            env.BASE_BRANCH = parsedInfo.mr_info.target_branch
                            env.ENGINE_BASE_BRANCH = parsedInfo.mr_info.target_branch
                        }
                    } else {
                        env.REVIEW_BRANCH = parsedInfo.issue_key
                    }

                    // Game MR info if provided
                    env.GAME_MR_URL = parsedInfo.containsKey('game_mr_url') ? (parsedInfo.game_mr_url ?: '') : ''
                    if (parsedInfo.containsKey('game_mr_info') && parsedInfo.game_mr_info != null && parsedInfo.game_mr_info.toString() != 'null') {
                        env.GAME_MR_BRANCH = parsedInfo.game_mr_info.branch ?: ''
                        env.GAME_BASE_BRANCH = parsedInfo.game_mr_info.target_branch ?: env.BASE_BRANCH
                    } else {
                        env.GAME_MR_BRANCH = ''
                        env.GAME_BASE_BRANCH = env.BASE_BRANCH
                    }

                    echo "Parsed: ${env.ISSUE_KEY} → ${env.PROJECT}"
                    echo "Engine: ${env.ENGINE_REPO}"
                    echo "Game:   ${env.GAME_REPO}"
                    echo "Branch: ${env.REVIEW_BRANCH} → ${env.BASE_BRANCH}"
                    echo "Engine base: ${env.ENGINE_BASE_BRANCH}"
                    echo "Game base: ${env.GAME_BASE_BRANCH}"

                    // Persist FEISHU_REPLY_MSG_ID to file for post block access
                    writeFile(file: "${env.WORKSPACE}/.feishu_reply_msg_id", text: "${params.FEISHU_REPLY_MSG_ID ?: ''}")
                }
            }
        }

        // ──────────────────────────────────────────────
        // Stage 2: Parallel Code Review (Engine + Game)
        // ──────────────────────────────────────────────
        stage('Code Review') {
            when { expression { env.ISSUE_KEY != null && env.ISSUE_KEY != '' } }
            parallel {
                stage('Engine Repo') {
                    steps {
                        script {
                            def engineBranch = env.REVIEW_BRANCH
                            def engineBase = env.ENGINE_BASE_BRANCH
                            def engineMrUrl = env.MR_URL
                            sh """
                                python3 ${SCRIPTS_DIR}/code_reviewer.py \
                                    --repo '${env.ENGINE_REPO}' \
                                    --branch '${engineBranch}' \
                                    --base-branch '${engineBase}' \
                                    --project '${env.PROJECT}' \
                                    --issue-key '${env.ISSUE_KEY}' \
                                    --repo-type 'engine' \
                                    --mr-url '${engineMrUrl}' \
                                    --workspace '${REVIEW_WORKSPACE}' \
                                    --output '${ENGINE_RESULT_FILE}'
                            """
                        }
                    }
                    post {
                        failure {
                            script {
                                writeJSON(file: ENGINE_RESULT_FILE, json: [
                                    project: env.PROJECT, issue_key: env.ISSUE_KEY,
                                    repo_type: 'engine', error: 'Review failed'
                                ])
                            }
                        }
                    }
                }

                stage('Game Repo') {
                    steps {
                        script {
                            def gameBranch = env.GAME_MR_BRANCH ?: env.REVIEW_BRANCH
                            def gameBase = env.GAME_BASE_BRANCH ?: env.BASE_BRANCH
                            def gameMrUrl = env.GAME_MR_URL ?: env.MR_URL
                            sh """
                                python3 ${SCRIPTS_DIR}/code_reviewer.py \
                                    --repo '${env.GAME_REPO}' \
                                    --branch '${gameBranch}' \
                                    --base-branch '${gameBase}' \
                                    --project '${env.PROJECT}' \
                                    --issue-key '${env.ISSUE_KEY}' \
                                    --repo-type 'game' \
                                    --mr-url '${gameMrUrl}' \
                                    --workspace '${REVIEW_WORKSPACE}' \
                                    --output '${GAME_RESULT_FILE}'
                            """
                        }
                    }
                    post {
                        failure {
                            script {
                                writeJSON(file: GAME_RESULT_FILE, json: [
                                    project: env.PROJECT, issue_key: env.ISSUE_KEY,
                                    repo_type: 'game', error: 'Review failed'
                                ])
                            }
                        }
                    }
                }
            }
        }
    }

    // ──────────────────────────────────────────────
    // Post: Send results to Feishu + update state
    // ──────────────────────────────────────────────
    post {
        success {
            script {
                if (env.ISSUE_KEY == null || env.ISSUE_KEY == '') {
                    echo "No issues to review — skipping notification"
                    return
                }

                // In scan mode (no explicit JIRA_URL), results were already sent inline
                def isScanMode = (params.JIRA_URL == null || params.JIRA_URL == '')
                if (isScanMode) {
                    echo "Scan mode — results already sent inline, skipping post notification"
                    return
                }

                def engineResult = fileExists(ENGINE_RESULT_FILE) ? readJSON(file: ENGINE_RESULT_FILE) : [:]
                def gameResult   = fileExists(GAME_RESULT_FILE)   ? readJSON(file: GAME_RESULT_FILE)   : [:]
                def feishuWebhook = env.FEISHU_WEBHOOK_URL ?: ''

                // Build severity summary with context
                def buildRepoBlock = { result, repoLabel, repoIcon ->
                    def sev = result.review?.severity_counts ?: [:]
                    def changedFiles = (result.changed_files ?: []).size()
                    def statsStr = result.stats ?: ''
                    def errorStr = result.review?.error ?: result.error ?: ''
                    def mrUrl = result.mr_url ?: ''
                    def branchMerged = result.branch_merged ?: false
                    def branchExists = result.containsKey('branch_exists') ? result.branch_exists : true

                    def text = "${repoIcon} **${repoLabel} 仓库**\n"
                    if (errorStr) {
                        text += "❌ 审查失败\n原因: ${errorStr}\n"
                    } else if (!branchExists) {
                        text += "⏭️ 跳过审查\n原因: 分支在远程仓库中不存在（可能已被删除或从未创建）\n"
                    } else if (branchMerged) {
                        text += "⏭️ 跳过审查\n原因: 分支已经合并到目标分支，没有新的代码变更\n"
                    } else if (changedFiles == 0) {
                        text += "⏭️ 跳过审查\n原因: 该分支相对于目标分支没有代码变更\n"
                    } else {
                        text += "变更文件: ${changedFiles} 个"
                        if (statsStr) text += " (${statsStr})"
                        text += "\n"
                        if (sev.get('critical'))  text += "🔴 Critical: ${sev.get('critical')}  "
                        if (sev.get('warning'))   text += "🟡 Warning: ${sev.get('warning')}  "
                        if (sev.get('suggestion')) text += "\nℹ️ Suggestion: ${sev.get('suggestion')}"
                        if (!sev.get('critical') && !sev.get('warning') && !sev.get('suggestion')) {
                            text += "✅ 未发现严重问题"
                        }
                    }
                    if (mrUrl) text += "\nMR: ${mrUrl}"
                    return text
                }

                def engineSev = ""
                def gameSev   = ""

                def topicParts = []
                topicParts.add("**🔍 Code Review: ${env.ISSUE_KEY}**")
                topicParts.add("项目: ${env.PROJECT}")
                topicParts.add("分支: ${env.REVIEW_BRANCH} → ${env.BASE_BRANCH}")
                topicParts.add("Jira: ${params.JIRA_URL}")
                topicParts.add("")
                topicParts.add(buildRepoBlock(engineResult, 'Engine', '🔧'))
                if (gameResult) {
                    topicParts.add("")
                    topicParts.add(buildRepoBlock(gameResult, 'Game', '🎮'))
                }
                def topicText = topicParts.join('\n')

                def feishuAppId = env.FEISHU_APP_ID ?: ''
                def feishuAppSecret = env.FEISHU_APP_SECRET ?: ''
                def feishuChatId = env.FEISHU_CHAT_ID ?: ''
                def topicMsgId = fileExists('.feishu_reply_msg_id') ? readFile('.feishu_reply_msg_id').trim() : ''

                if (feishuAppId && feishuAppSecret && feishuChatId) {
                    try {
                        if (topicMsgId) {
                            // ── Reply in existing topic (from FEISHU_REPLY_MSG_ID) ──
                            // 1) Send "Reviewing..." progress reply
                            def progressText = "🤖 **正在 Review...**\n已收到 ${env.ISSUE_KEY}，正在拉取代码并进行 AI 审查，请稍候..."
                            writeFile(file: "${env.WORKSPACE}/.fs_direct_progress.txt", text: progressText)
                            sh """
                                python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                    --app-id '${feishuAppId}' \
                                    --app-secret '${feishuAppSecret}' \
                                    --chat-id '${feishuChatId}' \
                                    --message-id '${topicMsgId}' \
                                    --message-file '${env.WORKSPACE}/.fs_direct_progress.txt'
                            """

                            // 2) Reply with summary (use --message-file to avoid base64 encoding issues)
                            writeFile(file: "${env.WORKSPACE}/.fs_direct_summary.txt", text: topicText)
                            sh """
                                python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                    --app-id '${feishuAppId}' \
                                    --app-secret '${feishuAppSecret}' \
                                    --chat-id '${feishuChatId}' \
                                    --message-id '${topicMsgId}' \
                                    --message-file '${env.WORKSPACE}/.fs_direct_summary.txt'
                            """

                            // 3) Reply with engine review details
                            if (engineResult.review?.review_text) {
                                def engineDetail = engineResult.review.review_text
                                def maxLen = 3000
                                if (engineDetail.length() > maxLen) {
                                    engineDetail = engineDetail.substring(0, maxLen) + "\n\n... (剩余内容请在 Jenkins 构建日志中查看)"
                                }
                                writeFile(file: 'feishu_engine_reply.json', text: "**🔧 Engine 详细报告:**\n${engineDetail}")
                                sh """
                                    python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                        --app-id '${feishuAppId}' \
                                        --app-secret '${feishuAppSecret}' \
                                        --chat-id '${feishuChatId}' \
                                        --message-id '${topicMsgId}' \
                                        --message-file '${env.WORKSPACE}/feishu_engine_reply.json'
                                """
                            }

                            // 4) Reply with game review details
                            if (gameResult.review?.review_text) {
                                def gameDetail = gameResult.review.review_text
                                def maxLen = 3000
                                if (gameDetail.length() > maxLen) {
                                    gameDetail = gameDetail.substring(0, maxLen) + "\n\n... (剩余内容请在 Jenkins 构建日志中查看)"
                                }
                                writeFile(file: 'feishu_game_reply.json', text: "**🎮 Game 详细报告:**\n${gameDetail}")
                                sh """
                                    python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                        --app-id '${feishuAppId}' \
                                        --app-secret '${feishuAppSecret}' \
                                        --chat-id '${feishuChatId}' \
                                        --message-id '${topicMsgId}' \
                                        --message-file '${env.WORKSPACE}/feishu_game_reply.json'
                                """
                            }
                        } else {
                            // ── New topic message (no FEISHU_REPLY_MSG_ID) ──
                            writeFile(file: "${env.WORKSPACE}/.fs_direct_topic.txt", text: topicText)
                            def topicResult = sh(
                                script: """
                                    python3 ${SCRIPTS_DIR}/feishu_notifier.py send-message \
                                        --app-id '${feishuAppId}' \
                                        --app-secret '${feishuAppSecret}' \
                                        --chat-id '${feishuChatId}' \
                                        --message-file '${env.WORKSPACE}/.fs_direct_topic.txt'
                                """,
                                returnStdout: true
                            ).trim()
                            def topicJson = readJSON(text: topicResult)
                            topicMsgId = topicJson.message_id ?: ''
                            echo "Topic message sent: ${topicMsgId}"

                            if (engineResult.review?.review_text && topicMsgId) {
                                def engineDetail = "**🔧 Engine 详细报告:**\n${engineResult.review.review_text}"
                                def maxLen = 3000
                                if (engineDetail.length() > maxLen) {
                                    engineDetail = engineDetail.substring(0, maxLen) + "\n\n... (剩余内容请在 Jenkins 构建日志中查看)"
                                }
                                writeFile(file: "${env.WORKSPACE}/.fs_detail_engine_${env.ISSUE_KEY}.txt", text: engineDetail)
                                sh """
                                    python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                        --app-id '${feishuAppId}' \
                                        --app-secret '${feishuAppSecret}' \
                                        --chat-id '${feishuChatId}' \
                                        --message-id '${topicMsgId}' \
                                        --message-file '${env.WORKSPACE}/.fs_detail_engine_${env.ISSUE_KEY}.txt'
                                """
                            }

                            if (gameResult.review?.review_text && topicMsgId) {
                                def gameDetail = "**🎮 Game 详细报告:**\n${gameResult.review.review_text}"
                                def maxLen = 3000
                                if (gameDetail.length() > maxLen) {
                                    gameDetail = gameDetail.substring(0, maxLen) + "\n\n... (剩余内容请在 Jenkins 构建日志中查看)"
                                }
                                writeFile(file: "${env.WORKSPACE}/.fs_detail_game_${env.ISSUE_KEY}.txt", text: gameDetail)
                                sh """
                                    python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                        --app-id '${feishuAppId}' \
                                        --app-secret '${feishuAppSecret}' \
                                        --chat-id '${feishuChatId}' \
                                        --message-id '${topicMsgId}' \
                                        --message-file '${env.WORKSPACE}/.fs_detail_game_${env.ISSUE_KEY}.txt'
                                """
                            }

                            env.FEISHU_TOPIC_MSG_ID = topicMsgId
                            }
                    } catch (Exception e) {
                        echo "Bot API notification failed, falling back to webhook: ${e}"
                        if (env.FEISHU_WEBHOOK_URL) {
                            writeFile(file: 'feishu_msg.json', text: topicText)
                            sh """
                                python3 ${SCRIPTS_DIR}/feishu_notifier.py webhook \
                                    --webhook-url '${env.FEISHU_WEBHOOK_URL}' \
                                    --message-file '${env.WORKSPACE}/feishu_msg.json'
                            """
                        }
                    }
                } else if (env.FEISHU_WEBHOOK_URL) {
                    writeFile(file: 'feishu_msg.json', text: topicText)
                    sh """
                        python3 ${SCRIPTS_DIR}/feishu_notifier.py webhook \
                            --webhook-url '${env.FEISHU_WEBHOOK_URL}' \
                            --message-file '${env.WORKSPACE}/feishu_msg.json'
                    """
                }

                // Mark as reviewed in state file
                def state = [:]
                if (fileExists(REVIEWED_STATE_FILE)) {
                    state = readJSON(file: REVIEWED_STATE_FILE)
                }
                def reviewed = state.reviewed ?: []
                if (!(env.ISSUE_KEY in reviewed)) {
                    reviewed.add(env.ISSUE_KEY)
                    // Keep last 200, trim oldest
                    if (reviewed.size() > 200) {
                        reviewed = reviewed[-200..-1]
                    }
                    writeJSON(file: REVIEWED_STATE_FILE, json: [reviewed: reviewed])
                    echo "Marked ${env.ISSUE_KEY} as reviewed"
                }
            }
        }

        failure {
            script {
                if (env.ISSUE_KEY != null && env.ISSUE_KEY != '') {
                    def topicMsgId = env.FEISHU_TOPIC_MSG_ID ?: ''
                    def feishuAppId = env.FEISHU_APP_ID ?: ''
                    def feishuAppSecret = env.FEISHU_APP_SECRET ?: ''

                    if (topicMsgId && feishuAppId && feishuAppSecret) {
                        def errText = "❌ **Code Review Failed**: ${env.ISSUE_KEY}\nBuild: ${BUILD_URL}"
                        writeFile(file: 'feishu_err_reply.json', text: errText)
                        sh """
                            python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                --app-id '${feishuAppId}' \
                                --app-secret '${feishuAppSecret}' \
                                --chat-id '${env.FEISHU_CHAT_ID}' \
                                --message-id '${topicMsgId}' \
                                --message-file '${env.WORKSPACE}/feishu_err_reply.json'
                        """
                    } else if (env.FEISHU_WEBHOOK_URL) {
                        def msgText = "❌ Code Review Failed: ${env.ISSUE_KEY}\nBuild: ${BUILD_URL}"
                        writeFile(file: 'feishu_err_msg.json', text: msgText)
                        sh """
                            python3 ${SCRIPTS_DIR}/feishu_notifier.py webhook \
                                --webhook-url '${env.FEISHU_WEBHOOK_URL}' \
                                --message-file '${env.WORKSPACE}/feishu_err_msg.json'
                        """
                    }
                }
            }
        }

        cleanup {
            sh "rm -rf ${REVIEW_WORKSPACE} ${SCAN_RESULT_FILE} ${PARSED_INFO_FILE} ${ENGINE_RESULT_FILE} ${GAME_RESULT_FILE} ${env.WORKSPACE}/engine_review.json ${env.WORKSPACE}/game_review.json ${env.WORKSPACE}/feishu_msg.json ${env.WORKSPACE}/feishu_err_msg.json ${env.WORKSPACE}/feishu_topic_msg.json ${env.WORKSPACE}/feishu_engine_reply.json ${env.WORKSPACE}/feishu_game_reply.json ${env.WORKSPACE}/feishu_err_reply.json ${env.WORKSPACE}/feishu_progress.json ${env.WORKSPACE}/feishu_summary_reply.json ${env.WORKSPACE}/.fs_*.txt ${env.WORKSPACE}/.feishu_reply_msg_id || true"
        }
    }
}

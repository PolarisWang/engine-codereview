#!/usr/bin/env groovy
/*
 * Code Review Pipeline
 *
 * Two modes:
 *   1. Scan mode (cron triggered, no JIRA_URL) — scan Jira for issues needing review
 *   2. Direct mode (JIRA_URL provided) — review a specific Jira issue
 *
 * Triggered by:
 *   - cron: every 30 minutes (scan mode)
 *   - manual: with JIRA_URL parameter
 *
 * Results are sent to Feishu group via webhook.
 */

pipeline {
    agent any

    triggers {
        // Disabled temporarily — cron flooding queue during testing
        // cron('* * * * *')
    }

    parameters {
        string(name: 'JIRA_URL', defaultValue: '',
               description: 'Jira issue URL (leave empty for auto-scan mode)')
        string(name: 'FEISHU_REPLY_MSG_ID', defaultValue: '',
               description: 'Feishu message ID to reply in (leave empty for new topic)')
    }

    environment {
        SCRIPTS_DIR = "${env.WORKSPACE}/jenkins/scripts"
        CONFIG_FILE = "${env.WORKSPACE}/config.yaml"
        REVIEW_WORKSPACE = "${env.WORKSPACE}/review-workspace"
        SCAN_RESULT_FILE = "${env.WORKSPACE}/scan_result.json"
        PARSED_INFO_FILE = "${env.WORKSPACE}/parsed_info.json"
        ENGINE_RESULT_FILE = "${env.WORKSPACE}/engine_result.json"
        GAME_RESULT_FILE = "${env.WORKSPACE}/game_result.json"
        REVIEWED_STATE_FILE = "/tmp/codereview-reviewed.json"   // Persist across runs

        // GitLab token for HTTPS clone + MR branch detection
        GITLAB_TOKEN = "${env.GITLAB_TOKEN ?: ''}"
        GITLAB_USER = "gitlab-ci-token"

        // Feishu Bot API (for topic messages)
        FEISHU_APP_ID = "${env.FEISHU_APP_ID ?: ''}"
        FEISHU_APP_SECRET = "${env.FEISHU_APP_SECRET ?: ''}"
        FEISHU_CHAT_ID = "${env.FEISHU_CHAT_ID ?: 'oc_254e95f0687245b9df82ab8bf823ca54'}"
        // Fallback webhook
        FEISHU_WEBHOOK_URL = "${env.FEISHU_WEBHOOK_URL_OVERRIDE ?: 'https://open.feishu.cn/open-apis/bot/v2/hook/f2ec1781-06d2-42c8-91b4-37616d973970'}"
        FEISHU_TOPIC_MSG_ID = ''
    }

    stages {
        // ──────────────────────────────────────────────
        // Stage 0: Scan — only when JIRA_URL is empty
        // ──────────────────────────────────────────────
        stage('Scan Jira Issues') {
            when { expression { params.JIRA_URL == null || params.JIRA_URL == '' } }
            steps {
                script {
                    sh """
                        python3 ${SCRIPTS_DIR}/jira_scanner.py \
                            --jira-host '${env.JIRA_HOST}' \
                            --jira-token '${env.JIRA_TOKEN}' \
                            --output '${SCAN_RESULT_FILE}' \
                            --state-file '${REVIEWED_STATE_FILE}'
                    """
                    scanResult = readJSON(file: SCAN_RESULT_FILE)
                    issues = scanResult.issues ?: []
                    echo "Found ${issues.size()} issues to review"

                    if (issues.isEmpty()) {
                        currentBuild.result = 'SUCCESS'
                    } else {
                        // Process first issue (one per run to keep results focused)
                        env.JIRA_URL = "https://${env.JIRA_HOST}/browse/${issues[0].key}"
                        echo "Auto-selected: ${env.JIRA_URL}"
                    }
                }
            }
        }

        // ──────────────────────────────────────────────
        // Stage 1: Parse Jira URL → project + MR info
        // ──────────────────────────────────────────────
        stage('Parse Jira Issue') {
            when { expression { params.JIRA_URL != null && params.JIRA_URL != '' } }
            steps {
                script {
                    sh """
                        python3 ${SCRIPTS_DIR}/jira_parser.py \
                            --jira-url '${params.JIRA_URL}' \
                            --jira-host '${env.JIRA_HOST}' \
                            --jira-token '${env.JIRA_TOKEN}' \
                            --gitlab-token '${env.GITLAB_TOKEN}' \
                            > ${PARSED_INFO_FILE}
                    """
                    parsedInfo = readJSON(file: PARSED_INFO_FILE)

                    if (parsedInfo.containsKey('error')) {
                        error("Jira parse failed: ${parsedInfo.error}")
                    }

                    env.ISSUE_KEY   = parsedInfo.issue_key
                    env.PROJECT     = parsedInfo.project
                    env.ENGINE_REPO = parsedInfo.engine_repo
                    env.GAME_REPO   = parsedInfo.game_repo
                    env.BASE_BRANCH = parsedInfo.default_branch
                    env.ENGINE_BASE_BRANCH = parsedInfo.containsKey('engine_default_branch') ? parsedInfo.engine_default_branch : parsedInfo.default_branch
                    env.MR_URL      = parsedInfo.mr_url ?: ''

                    if (parsedInfo.mr_info != null && parsedInfo.mr_info.toString() != 'null') {
                        env.REVIEW_BRANCH = parsedInfo.mr_info.branch ?: parsedInfo.issue_key
                        // Use MR target_branch as base if available
                        if (parsedInfo.mr_info.target_branch) {
                            env.BASE_BRANCH = parsedInfo.mr_info.target_branch
                            env.ENGINE_BASE_BRANCH = parsedInfo.mr_info.target_branch
                        }
                    } else {
                        env.REVIEW_BRANCH = parsedInfo.issue_key
                    }

                    // Game MR info if provided
                    env.GAME_MR_URL = parsedInfo.containsKey('game_mr_url') ? (parsedInfo.game_mr_url ?: '') : ''
                    if (parsedInfo.containsKey('game_mr_info') && parsedInfo.game_mr_info != null && parsedInfo.game_mr_info.toString() != 'null') {
                        env.GAME_MR_BRANCH = parsedInfo.game_mr_info.branch ?: ''
                        env.GAME_BASE_BRANCH = parsedInfo.game_mr_info.target_branch ?: env.BASE_BRANCH
                    } else {
                        env.GAME_MR_BRANCH = ''
                        env.GAME_BASE_BRANCH = env.BASE_BRANCH
                    }

                    echo "Parsed: ${env.ISSUE_KEY} → ${env.PROJECT}"
                    echo "Engine: ${env.ENGINE_REPO}"
                    echo "Game:   ${env.GAME_REPO}"
                    echo "Branch: ${env.REVIEW_BRANCH} → ${env.BASE_BRANCH}"
                    echo "Engine base: ${env.ENGINE_BASE_BRANCH}"
                    echo "Game base: ${env.GAME_BASE_BRANCH}"

                    // Set FEISHU_TOPIC_MSG_ID from params (params is available inside script blocks)
                    env.FEISHU_TOPIC_MSG_ID = params.FEISHU_REPLY_MSG_ID ?: ''
                    echo "Feishu reply mode: ${env.FEISHU_TOPIC_MSG_ID ? 'replying in thread' : 'new topic'}"
                }
            }
        }

        // ──────────────────────────────────────────────
        // Stage 2: Parallel Code Review (Engine + Game)
        // ──────────────────────────────────────────────
        stage('Code Review') {
            when { expression { env.ISSUE_KEY != null && env.ISSUE_KEY != '' } }
            parallel {
                stage('Engine Repo') {
                    steps {
                        script {
                            def engineBranch = env.REVIEW_BRANCH
                            def engineBase = env.ENGINE_BASE_BRANCH
                            def engineMrUrl = env.MR_URL
                            sh """
                                python3 ${SCRIPTS_DIR}/code_reviewer.py \
                                    --repo '${env.ENGINE_REPO}' \
                                    --branch '${engineBranch}' \
                                    --base-branch '${engineBase}' \
                                    --project '${env.PROJECT}' \
                                    --issue-key '${env.ISSUE_KEY}' \
                                    --repo-type 'engine' \
                                    --mr-url '${engineMrUrl}' \
                                    --workspace '${REVIEW_WORKSPACE}' \
                                    --output '${ENGINE_RESULT_FILE}'
                            """
                        }
                    }
                    post {
                        failure {
                            script {
                                writeJSON(file: ENGINE_RESULT_FILE, json: [
                                    project: env.PROJECT, issue_key: env.ISSUE_KEY,
                                    repo_type: 'engine', error: 'Review failed'
                                ])
                            }
                        }
                    }
                }

                stage('Game Repo') {
                    steps {
                        script {
                            def gameBranch = env.GAME_MR_BRANCH ?: env.REVIEW_BRANCH
                            def gameBase = env.GAME_BASE_BRANCH ?: env.BASE_BRANCH
                            def gameMrUrl = env.GAME_MR_URL ?: env.MR_URL
                            sh """
                                python3 ${SCRIPTS_DIR}/code_reviewer.py \
                                    --repo '${env.GAME_REPO}' \
                                    --branch '${gameBranch}' \
                                    --base-branch '${gameBase}' \
                                    --project '${env.PROJECT}' \
                                    --issue-key '${env.ISSUE_KEY}' \
                                    --repo-type 'game' \
                                    --mr-url '${gameMrUrl}' \
                                    --workspace '${REVIEW_WORKSPACE}' \
                                    --output '${GAME_RESULT_FILE}'
                            """
                        }
                    }
                    post {
                        failure {
                            script {
                                writeJSON(file: GAME_RESULT_FILE, json: [
                                    project: env.PROJECT, issue_key: env.ISSUE_KEY,
                                    repo_type: 'game', error: 'Review failed'
                                ])
                            }
                        }
                    }
                }
            }
        }
    }

    // ──────────────────────────────────────────────
    // Post: Send results to Feishu + update state
    // ──────────────────────────────────────────────
    post {
        success {
            script {
                if (env.ISSUE_KEY == null || env.ISSUE_KEY == '') {
                    echo "No issues to review — skipping notification"
                    return
                }

                def engineResult = fileExists(ENGINE_RESULT_FILE) ? readJSON(file: ENGINE_RESULT_FILE) : [:]
                def gameResult   = fileExists(GAME_RESULT_FILE)   ? readJSON(file: GAME_RESULT_FILE)   : [:]
                def feishuWebhook = env.FEISHU_WEBHOOK_URL ?: ''

                // Build severity summary
                def buildSevText = { result ->
                    def sev = result.review?.severity_counts ?: [:]
                    def parts = []
                    if (sev.critical)  parts.append("🔴 ${sev.critical}")
                    if (sev.warning)   parts.append("🟡 ${sev.warning}")
                    if (sev.suggestion)parts.append("ℹ️ ${sev.suggestion}")
                    return parts ? parts.join(' | ') : '✅ Clean'
                }
                engineSev = buildSevText(engineResult)
                gameSev   = buildSevText(gameResult)

                // Count changed files
                def engineFiles = (engineResult.changed_files ?: []).size()
                def gameFiles   = (gameResult.changed_files   ?: []).size()

                // Build topic message
                def buildTopicText = { repoType, result ->
                    def sev = result.review?.severity_counts ?: [:]
                    def reviewText = result.review?.review_text ?: ''
                    def changedFiles = (result.changed_files ?: []).size()
                    def mrUrl = result.mr_url ?: ''

                    def text = "**${repoType == 'engine' ? '🔧' : '🎮'} ${repoType == 'engine' ? 'Engine' : 'Game'} 仓库**\n"
                    text += "${changedFiles} files changed\n"
                    if (sev.critical)  text += "🔴 Critical: ${sev.critical}  "
                    if (sev.warning)   text += "🟡 Warning: ${sev.warning}  "
                    if (sev.suggestion)text += "ℹ️ Suggestion: ${sev.suggestion}"
                    if (!sev.critical && !sev.warning && !sev.suggestion) text += "✅ No issues found"
                    if (mrUrl) text += "\nMR: ${mrUrl}"
                    return text
                }

                def topicParts = []
                topicParts.add("**🔍 Code Review: ${env.ISSUE_KEY}**")
                topicParts.add("Project: ${env.PROJECT}")
                topicParts.add("Jira: ${params.JIRA_URL}")
                topicParts.add("")
                topicParts.add(buildTopicText('engine', engineResult))
                if (gameResult && gameResult.review?.review_text) {
                    topicParts.add("")
                    topicParts.add(buildTopicText('game', gameResult))
                }
                def topicText = topicParts.join('\n')

                def feishuAppId = env.FEISHU_APP_ID ?: ''
                def feishuAppSecret = env.FEISHU_APP_SECRET ?: ''
                def feishuChatId = env.FEISHU_CHAT_ID ?: ''
                def topicMsgId = env.FEISHU_TOPIC_MSG_ID ?: ''

                if (feishuAppId && feishuAppSecret && feishuChatId) {
                    try {
                        if (topicMsgId) {
                            // ── Reply in existing topic (from FEISHU_REPLY_MSG_ID) ──
                            // 1) Send "Reviewing..." progress reply
                            def progressText = "🤖 **正在 Review...**\n已收到 ${env.ISSUE_KEY}，正在拉取代码并进行 AI 审查，请稍候..."
                            writeFile(file: 'feishu_progress.json', text: progressText)
                            sh """
                                python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                    --app-id '${feishuAppId}' \
                                    --app-secret '${feishuAppSecret}' \
                                    --chat-id '${feishuChatId}' \
                                    --message-id '${topicMsgId}' \
                                    --message-file '${env.WORKSPACE}/feishu_progress.json'
                            """

                            // 2) Reply with summary
                            writeFile(file: 'feishu_summary_reply.json', text: topicText)
                            sh """
                                python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                    --app-id '${feishuAppId}' \
                                    --app-secret '${feishuAppSecret}' \
                                    --chat-id '${feishuChatId}' \
                                    --message-id '${topicMsgId}' \
                                    --message-file '${env.WORKSPACE}/feishu_summary_reply.json'
                            """

                            // 3) Reply with engine review details
                            if (engineResult.review?.review_text) {
                                def engineDetail = engineResult.review.review_text
                                def maxLen = 3000
                                if (engineDetail.length() > maxLen) {
                                    engineDetail = engineDetail.substring(0, maxLen) + "\n\n... (剩余内容请在 Jenkins 构建日志中查看)"
                                }
                                writeFile(file: 'feishu_engine_reply.json', text: "**🔧 Engine 详细报告:**\n${engineDetail}")
                                sh """
                                    python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                        --app-id '${feishuAppId}' \
                                        --app-secret '${feishuAppSecret}' \
                                        --chat-id '${feishuChatId}' \
                                        --message-id '${topicMsgId}' \
                                        --message-file '${env.WORKSPACE}/feishu_engine_reply.json'
                                """
                            }

                            // 4) Reply with game review details
                            if (gameResult.review?.review_text) {
                                def gameDetail = gameResult.review.review_text
                                def maxLen = 3000
                                if (gameDetail.length() > maxLen) {
                                    gameDetail = gameDetail.substring(0, maxLen) + "\n\n... (剩余内容请在 Jenkins 构建日志中查看)"
                                }
                                writeFile(file: 'feishu_game_reply.json', text: "**🎮 Game 详细报告:**\n${gameDetail}")
                                sh """
                                    python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                        --app-id '${feishuAppId}' \
                                        --app-secret '${feishuAppSecret}' \
                                        --chat-id '${feishuChatId}' \
                                        --message-id '${topicMsgId}' \
                                        --message-file '${env.WORKSPACE}/feishu_game_reply.json'
                                """
                            }
                        } else {
                            // ── New topic message (no FEISHU_REPLY_MSG_ID) ──
                            writeFile(file: 'feishu_topic_msg.json', text: topicText)
                            def topicResult = sh(
                                script: """
                                    python3 ${SCRIPTS_DIR}/feishu_notifier.py send-message \
                                        --app-id '${feishuAppId}' \
                                        --app-secret '${feishuAppSecret}' \
                                        --chat-id '${feishuChatId}' \
                                        --message-file '${env.WORKSPACE}/feishu_topic_msg.json'
                                """,
                                returnStdout: true
                            ).trim()
                            def topicJson = readJSON(text: topicResult)
                            topicMsgId = topicJson.message_id ?: ''
                            echo "Topic message sent: ${topicMsgId}"

                            if (engineResult.review?.review_text && topicMsgId) {
                                def engineDetail = engineResult.review.review_text
                                def maxLen = 3000
                                if (engineDetail.length() > maxLen) {
                                    engineDetail = engineDetail.substring(0, maxLen) + "\n\n... (剩余内容请在 Jenkins 构建日志中查看)"
                                }
                                writeFile(file: 'feishu_engine_reply.json', text: "**🔧 Engine 详细报告:**\n${engineDetail}")
                                sh """
                                    python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                        --app-id '${feishuAppId}' \
                                        --app-secret '${feishuAppSecret}' \
                                        --chat-id '${feishuChatId}' \
                                        --message-id '${topicMsgId}' \
                                        --message-file '${env.WORKSPACE}/feishu_engine_reply.json'
                                """
                            }

                            if (gameResult.review?.review_text && topicMsgId) {
                                def gameDetail = gameResult.review.review_text
                                def maxLen = 3000
                                if (gameDetail.length() > maxLen) {
                                    gameDetail = gameDetail.substring(0, maxLen) + "\n\n... (剩余内容请在 Jenkins 构建日志中查看)"
                                }
                                writeFile(file: 'feishu_game_reply.json', text: "**🎮 Game 详细报告:**\n${gameDetail}")
                                sh """
                                    python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                        --app-id '${feishuAppId}' \
                                        --app-secret '${feishuAppSecret}' \
                                        --chat-id '${feishuChatId}' \
                                        --message-id '${topicMsgId}' \
                                        --message-file '${env.WORKSPACE}/feishu_game_reply.json'
                                """
                            }

                            env.FEISHU_TOPIC_MSG_ID = topicMsgId
                        }
                    } catch (Exception e) {
                        echo "Bot API notification failed, falling back to webhook: ${e}"
                        if (env.FEISHU_WEBHOOK_URL) {
                            writeFile(file: 'feishu_msg.json', text: topicText)
                            sh """
                                python3 ${SCRIPTS_DIR}/feishu_notifier.py webhook \
                                    --webhook-url '${env.FEISHU_WEBHOOK_URL}' \
                                    --message-file '${env.WORKSPACE}/feishu_msg.json'
                            """
                        }
                    }
                } else if (env.FEISHU_WEBHOOK_URL) {
                    writeFile(file: 'feishu_msg.json', text: topicText)
                    sh """
                        python3 ${SCRIPTS_DIR}/feishu_notifier.py webhook \
                            --webhook-url '${env.FEISHU_WEBHOOK_URL}' \
                            --message-file '${env.WORKSPACE}/feishu_msg.json'
                    """
                }

                // Mark as reviewed in state file
                def state = [:]
                if (fileExists(REVIEWED_STATE_FILE)) {
                    state = readJSON(file: REVIEWED_STATE_FILE)
                }
                def reviewed = state.reviewed ?: []
                if (!(env.ISSUE_KEY in reviewed)) {
                    reviewed.add(env.ISSUE_KEY)
                    // Keep last 200, trim oldest
                    if (reviewed.size() > 200) {
                        reviewed = reviewed[-200..-1]
                    }
                    writeJSON(file: REVIEWED_STATE_FILE, json: [reviewed: reviewed])
                    echo "Marked ${env.ISSUE_KEY} as reviewed"
                }
            }
        }

        failure {
            script {
                if (env.ISSUE_KEY != null && env.ISSUE_KEY != '') {
                    def topicMsgId = env.FEISHU_TOPIC_MSG_ID ?: ''
                    def feishuAppId = env.FEISHU_APP_ID ?: ''
                    def feishuAppSecret = env.FEISHU_APP_SECRET ?: ''

                    if (topicMsgId && feishuAppId && feishuAppSecret) {
                        def errText = "❌ **Code Review Failed**: ${env.ISSUE_KEY}\nBuild: ${BUILD_URL}"
                        writeFile(file: 'feishu_err_reply.json', text: errText)
                        sh """
                            python3 ${SCRIPTS_DIR}/feishu_notifier.py reply-message \
                                --app-id '${feishuAppId}' \
                                --app-secret '${feishuAppSecret}' \
                                --chat-id '${env.FEISHU_CHAT_ID}' \
                                --message-id '${topicMsgId}' \
                                --message-file '${env.WORKSPACE}/feishu_err_reply.json'
                        """
                    } else if (env.FEISHU_WEBHOOK_URL) {
                        def msgText = "❌ Code Review Failed: ${env.ISSUE_KEY}\nBuild: ${BUILD_URL}"
                        writeFile(file: 'feishu_err_msg.json', text: msgText)
                        sh """
                            python3 ${SCRIPTS_DIR}/feishu_notifier.py webhook \
                                --webhook-url '${env.FEISHU_WEBHOOK_URL}' \
                                --message-file '${env.WORKSPACE}/feishu_err_msg.json'
                        """
                    }
                }
            }
        }

        cleanup {
            sh "rm -rf ${REVIEW_WORKSPACE} ${SCAN_RESULT_FILE} ${PARSED_INFO_FILE} ${ENGINE_RESULT_FILE} ${GAME_RESULT_FILE} ${env.WORKSPACE}/engine_review.json ${env.WORKSPACE}/game_review.json ${env.WORKSPACE}/feishu_msg.json ${env.WORKSPACE}/feishu_err_msg.json ${env.WORKSPACE}/feishu_topic_msg.json ${env.WORKSPACE}/feishu_engine_reply.json ${env.WORKSPACE}/feishu_game_reply.json ${env.WORKSPACE}/feishu_err_reply.json ${env.WORKSPACE}/feishu_progress.json ${env.WORKSPACE}/feishu_summary_reply.json || true"
        }
    }
}
